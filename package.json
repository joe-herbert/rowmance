{
  "name": "rowmance",
  "version": "0.1.0",
  "description": "A keyboard-driven desktop database client for MySQL, MariaDB and PostgreSQL.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "bunx svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bunx svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint src/ && prettier --check src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "bits-ui": "^1",
    "@codemirror/autocomplete": "^6",
    "@codemirror/commands": "^6",
    "@codemirror/lang-sql": "^6",
    "@codemirror/language": "^6",
    "@codemirror/state": "^6",
    "@codemirror/theme-one-dark": "^6",
    "@codemirror/view": "^6",
    "codemirror": "^6",
    "fuse.js": "^7",
    "sql-formatter": "^15",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3",
    "@sveltejs/kit": "^2",
    "@sveltejs/vite-plugin-svelte": "^5",
    "@tauri-apps/cli": "^2",
    "@testing-library/svelte": "^5",
    "@testing-library/jest-dom": "^6",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitest/coverage-v8": "^2",
    "eslint": "^9",
    "eslint-plugin-svelte": "^2",
    "jsdom": "^25",
    "prettier": "^3",
    "prettier-plugin-svelte": "^3",
    "svelte-check": "^4",
    "typescript": "~5.6.2",
    "vite": "^6",
    "vitest": "^2"
  }
}
