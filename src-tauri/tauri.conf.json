{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rowmance",
  "version": "2.1.1",
  "identifier": "com.jherbert.rowmance",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Rowmance",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 30, "y": 30 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVCNTNENEMzNTcwRTI2ODMKUldTREpnNVh3OVJUNjZRMUhzcDMzWEE5bXNzVTlFbTR1L3hxM1ZGMStXOW9hcThzZTl2TllyaVAK",
      "endpoints": [
        "https://github.com/joe-herbert/rowmance/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "entitlements.plist",
      "files": {
        "embedded.provisionprofile": "embedded.provisionprofile"
      },
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": { "width": 540, "height": 380 },
        "appPosition": { "x": 130, "y": 190 },
        "applicationFolderPosition": { "x": 410, "y": 190 }
      }
    },
    "fileAssociations": [
      {
        "ext": ["sqlite", "db", "sqlite3"],
        "name": "SQLite Database",
        "description": "SQLite Database File",
        "mimeType": "application/x-sqlite3",
        "role": "Editor"
      },
      {
        "ext": ["sql"],
        "name": "SQL Script",
        "description": "SQL Script File",
        "mimeType": "application/sql",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
