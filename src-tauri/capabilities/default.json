{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "rowmance-*"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-start-dragging",
    "core:webview:allow-create-webview-window",
    "fs:default",
    "dialog:default",
    "shell:default",
    "updater:default"
  ]
}
